# OppTrax Environment Configuration Example
# Copy this file to '.env' in the same folder and fill in the values.

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Gemini API
GEMINI_KEY=your_gemini_api_key_here

# Sarvam AI API
SARVAM_KEY=your_sarvam_api_key_here

# Yutori API
YUTORI_KEY=your_yutori_api_key_here

# WhatsApp Cloud API Configuration
WHATSAPP_TOKEN=your_whatsapp_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# Ngrok Public URL (for Webhooks)
NGROK_BASE_URL=https://your-subdomain.ngrok-free.app

# (Optional) WhatsApp Template name for OTP if you want to use template messages in production
WHATSAPP_OTP_TEMPLATE_NAME=your_auth_otp_template_name_here

